# Required — Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional — enables live web search; without it, offline knowledge only
TAVILY_API_KEY=

# Optional — defaults to gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional — swappable diagnostic agent worker (see HARNESS.md)
# DIAGNOSTIC_AGENT=tool-calling
# DIAGNOSTIC_AGENT=single-pass
